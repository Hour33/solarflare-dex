# Frontend environment variables
# Copy to .env.local and fill in values from your script outputs

NEXT_PUBLIC_NETWORK=devnet
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# From Script 1 output
NEXT_PUBLIC_TOKEN_MINT=YOUR_TOKEN_MINT_ADDRESS
NEXT_PUBLIC_TOKEN_SYMBOL=MTK
NEXT_PUBLIC_TOKEN_NAME=MyToken
NEXT_PUBLIC_TOKEN_DECIMALS=6

# From Script 3 output
NEXT_PUBLIC_POOL_ID=YOUR_RAYDIUM_POOL_AMM_ID
